    <!-- [STUDIO:"query-facilities-by-supplier"]<flow name="query-facilities-by-supplier" doc:name="GET: Query Facilities By Supplier">
        <try doc:name="TRY: Query Paginated Facilities">
            <ee:transform doc:name="SET: Pagination Params">
                <ee:variables>
                    <ee:set-variable variableName="pageSize"><![CDATA[%dw 2.0
output application/java
&#45;&#45;-
(attributes.queryParams.limit default 25) as Number&#93;&#93;></ee:set-variable>
                    <ee:set-variable variableName="afterCursor"><![CDATA[%dw 2.0
output application/java
&#45;&#45;-
attributes.queryParams.after&#93;&#93;></ee:set-variable>
                    <ee:set-variable variableName="beforeCursor"><![CDATA[%dw 2.0
output application/java
&#45;&#45;-
attributes.queryParams.before&#93;&#93;></ee:set-variable>
                </ee:variables>
            </ee:transform>
            <ee:transform doc:name="BUILD: Cursor SOQL Query">
                <ee:variables>
                    <ee:set-variable variableName="soql"><![CDATA[%dw 2.0
import dataweave::util::Pagination
output application/java

var safeSupplierId = if (Pagination::isValidUuid(vars.id)) vars.id else ""
var safeBefore = if (vars.beforeCursor != null and Pagination::isValidUuid(vars.beforeCursor)) vars.beforeCursor else null
var safeAfter = if (vars.afterCursor != null and Pagination::isValidUuid(vars.afterCursor)) vars.afterCursor else null
var baseQuery = "SELECT UUID__c, Name, Type__c, isActive__c, AvgLeadTimeInDays__c, Address__r.UUID__c, Address__r.StreetAddress__c, Address__r.City__c, Address__r.State__c, Address__r.PostalCode__c, Address__r.Country__c FROM Facility__c WHERE Supplier__r.UUID__c = '" ++ safeSupplierId ++ "'"
&#45;&#45;-
if (safeBefore != null)
    baseQuery ++ " AND UUID__c < '" ++ safeBefore ++ "' ORDER BY UUID__c DESC LIMIT " ++ (vars.pageSize + 1)
else if (safeAfter != null)
    baseQuery ++ " AND UUID__c > '" ++ safeAfter ++ "' ORDER BY UUID__c ASC LIMIT " ++ (vars.pageSize + 1)
else
    baseQuery ++ " ORDER BY UUID__c ASC LIMIT " ++ (vars.pageSize + 1)&#93;&#93;></ee:set-variable>
                </ee:variables>
            </ee:transform>
            <salesforce:query config-ref="SalesforceConfig" doc:name="QUERY: Paginated Facilities">
                <salesforce:salesforce-query>#[vars.soql&#93;</salesforce:salesforce-query>
            </salesforce:query>
            <logger level="INFO" doc:name="LOG: Raw Query Result" message="#[%dw 2.0 import toString from dw::util::Coercions &#45;&#45;- &quot;[$(toString(now()))&#93; Raw Query Result: $(write(payload, 'application/json'))&quot;&#93;" />
            <ee:transform doc:name="MAP: Paginated Facilities">
                <ee:message>
                    <ee:set-payload><![CDATA[%dw 2.0
import dataweave::util::Pagination
output application/json

var result = Pagination::paginate(payload, vars.pageSize, vars.afterCursor, vars.beforeCursor)
&#45;&#45;-
{
    paging: {
        cursors: {
            before: result.before,
            after: result.after
        },
        hasNext: result.after != null,
        hasPrevious: result.before != null,
        limit: vars.pageSize
    },
    results: result.data map {
        id: $.UUID__c,
        name: $.Name,
        facilityType: $.Type__c,
        avgLeadTimeInDays: $.AvgLeadTimeInDays__c,
        isActive: $.isActive__c,
        address: {
            streetAddress: $.Address__r.StreetAddress__c,
            city: $.Address__r.City__c,
            state: $.Address__r.State__c,
            postalCode: $.Address__r.PostalCode__c,
            country: $.Address__r.Country__c
        }
    }
}&#93;&#93;></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus"><![CDATA[200&#93;&#93;></ee:set-variable>
                </ee:variables>
            </ee:transform>
            <error-handler ref="error-handlers__handle-salesforce-failures" />
        </try>
    </flow> [STUDIO] -->

