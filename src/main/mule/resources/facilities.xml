    <sub-flow name="validate-facility" doc:name="VALIDATE: Facility">
        <choice doc:name="CHECK: Name Not Blank">
            <when expression="#[payload.name?]">
                <validation:is-not-blank-string value="#[payload.name]" message="Facility name cannot be blank.">
                    <error-mapping sourceType="VALIDATION:BLANK_STRING" targetType="VALIDATION_FAILURE:BLANK_NAME" />
                </validation:is-not-blank-string>
            </when>
        </choice>
        <choice doc:name="CHECK: Facility Type Valid">
            <when expression="#[payload.facilityType?]">
                <validation:is-true expression="#[payload.facilityType is String and ['Warehouse', 'Manufacturing', 'Distribution', 'Office'] contains payload.facilityType]" message="Facility type must be one of: Warehouse, Manufacturing, Distribution, Office.">
                    <error-mapping sourceType="VALIDATION:INVALID_BOOLEAN" targetType="VALIDATION_FAILURE:INVALID_FIELD" />
                </validation:is-true>
            </when>
        </choice>
        <choice doc:name="CHECK: Avg Lead Time Valid">
            <when expression="#[payload.avgLeadTimeInDays?]">
                <validation:is-true expression="#[payload.avgLeadTimeInDays is Number and payload.avgLeadTimeInDays >= 1]" message="Average lead time must be a number >= 1.">
                    <error-mapping sourceType="VALIDATION:INVALID_BOOLEAN" targetType="VALIDATION_FAILURE:INVALID_FIELD" />
                </validation:is-true>
            </when>
        </choice>
        <choice doc:name="CHECK: Is Active Valid">
            <when expression="#[payload.isActive?]">
                <validation:is-true expression="#[payload.isActive is Boolean]" message="isActive must be a boolean.">
                    <error-mapping sourceType="VALIDATION:INVALID_BOOLEAN" targetType="VALIDATION_FAILURE:INVALID_FIELD" />
                </validation:is-true>
            </when>
        </choice>
        <choice doc:name="CHECK: Address Valid UUID">
            <when expression="#[payload.address?]">
                <validation:is-true expression="#[payload.address matches /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/]" message="Address must be a valid UUID.">
                    <error-mapping sourceType="VALIDATION:INVALID_BOOLEAN" targetType="VALIDATION_FAILURE:INVALID_FIELD" />
                </validation:is-true>
            </when>
        </choice>
    </sub-flow>

    <flow name="create-facility" doc:name="CREATE: Facility">
        <try doc:name="TRY: Create Facility in Salesforce">
            <ee:transform doc:name="SET/CREATE: UUIDs for Supplier, Address and Facility" doc:id="ea12fd51-6ea6-4e6b-9937-388344300947" >
				<ee:message >
				</ee:message>
				<ee:variables >
					<ee:set-variable variableName="facilityUuid" ><![CDATA[import uuid7 from dataweave::util::Id --- uuid7()]]></ee:set-variable>
					<ee:set-variable variableName="addressUuid" ><![CDATA[import uuid7 from dataweave::util::Id --- uuid7()]]></ee:set-variable>
					<ee:set-variable variableName="supplierUuid" ><![CDATA[%dw 2.0
output application/java
---
vars.id]]></ee:set-variable>
				</ee:variables>
			</ee:transform>
			<salesforce-composite:execute-composite-request doc:name="CREATE: Facility with Address" doc:id="93b8f258-7715-4ed5-8de1-1f2c60cf6ae2" config-ref="SalesforceCompositeConfig" target="createFacilityResult">
				<salesforce-composite:request-body ><![CDATA[#[%dw 2.0
output application/json
var apiVersion = "v66.0"
---
{
	allOrNone: true,
	compositeRequest: [
		{
			referenceId: "supplierLookup",
			method: "GET",
			url: "/services/data/$(apiVersion)/query?q=SELECT+Id+FROM+Supplier__c+WHERE+UUID__c='$(vars.supplierUuid)'+LIMIT+1"
		},
		{
			referenceId: "createFacility",
			method: "POST",
			url: "/services/data/$(apiVersion)/sobjects/Facility__c",
			body: {
				UUID__c: vars.facilityUuid,
				Supplier__c: "@{supplierLookup.records[0].Id}",
				Name: payload.name,
				Type__c: payload.facilityType,
				(AvgLeadTimeInDays__c: payload.avgLeadTimeInDays as Number) if (payload.avgLeadTimeInDays != null),
				(isActive__c: payload.isActive as Boolean) if (payload.isActive != null)
			}
		},
		{
			referenceId: "createAddress",
			method: "POST",
			url: "/services/data/$(apiVersion)/sobjects/SupplierAddress__c",
			body: {
				UUID__c: vars.addressUuid,
				Street__c: payload.address.street,
				City__c: payload.address.city,
				State__c: payload.address.state,
				PostalCode__c: payload.address.postalCode,
				Country__c: payload.address.country,
				Facility__c: "@{createFacility.id}",
			}
		},
		
	]
}]]]></salesforce-composite:request-body>
			</salesforce-composite:execute-composite-request>
            <choice doc:name="CHECK: Composite Succeeded">
                <when expression="#[%dw 2.0&#10;import every from dw::core::Arrays&#10;---&#10;vars.createFacilityResult.compositeResponse every ($.httpStatusCode &gt;= 400)]">
                    <logger level="ERROR" doc:name="ERROR: Composite Failure" message="#[%dw 2.0 import toString from dw::util::Coercions --- &quot;[$(toString(now()))] Composite create-facility failed: $(write(vars.createFacilityResult, 'application/json'))&quot;]" />
                    <raise-error doc:name="RAISE: Salesforce Error" type="VALIDATION_FAILURE:SALESFORCE" description="Failed to create facility in Salesforce." />
                </when>
				<otherwise >
					<logger level="INFO" doc:name="INFO: Facility Created" message='#[%dw 2.0 import toString from dw::util::Coercions --- "[$(toString(now()))] Facility created: $(vars.facilityUuid)"]' />
				</otherwise>
            
</choice>
            <error-handler ref="error-handlers__handle-salesforce-failures" />
        </try>
        <ee:transform doc:name="SET: 201 Created Response">
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
    id: vars.facilityUuid
}]]></ee:set-payload>
            </ee:message>
            <ee:variables>
                <ee:set-variable variableName="httpStatus"><![CDATA[201]]></ee:set-variable>
            </ee:variables>
        </ee:transform>
        <error-handler ref="error-handlers__handle-validation-failures" />
    </flow>

